{
  "name": "@data-stone/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Data Stone Global Design System — componentes Vue + Nuxt Layer compartilhados pelos frontends.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Data-Stone/datastone-ui.git"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./components/*": "./components/*",
    "./composables": "./composables/index.ts",
    "./utils": "./utils/index.ts",
    "./tokens.css": "./assets/css/tokens.css",
    "./nuxt": "./nuxt.config.ts"
  },
  "files": [
    "components",
    "composables",
    "utils",
    "assets",
    "index.ts",
    "nuxt.config.ts",
    "types.ts"
  ],
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "lint": "eslint .",
    "type-check": "vue-tsc --noEmit",
    "type-check:publish": "vue-tsc --noEmit -p tsconfig.publish.json",
    "prepublishOnly": "pnpm run type-check:publish"
  },
  "peerDependencies": {
    "@nuxt/ui": "^4.0.0",
    "nuxt": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/test": "^8.6.18",
    "@storybook/vue3": "^8.4.7",
    "@storybook/vue3-vite": "^8.4.7",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.9.1",
    "storybook": "^8.4.7",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "vite": "^6.0.0",
    "vue": "^3.5.18",
    "vue-tsc": "^2.2.0"
  }
}
