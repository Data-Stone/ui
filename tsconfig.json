{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "index.ts",
    "types.ts",
    "components/**/*.vue",
    "components/**/*.ts",
    "composables/**/*.ts",
    "stories/**/*.ts",
    ".storybook/**/*.ts"
  ],
  "exclude": ["node_modules", "storybook-static", "dist"]
}
